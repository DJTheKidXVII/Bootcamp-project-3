package week11;

public class Main {

    public static void main(String[] args){

        PlayerService service =
        new PlayerService();

        service.addPlayer(
        new Player(1,"Ram",
        "Gopal",26));

        service.addPlayer(
        new Player(2,"John",
        "Mayer",22));

        service.updatePlayer(
        new Player(1,"Rama",
        "Gopala",24));

        service.deletePlayer(1);

        service.averageAge();

        service.drop();
    }
}
